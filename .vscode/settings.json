  "files.associations": {
    "*.input": "ini",
    "array": "cpp",
    "*.tcc": "cpp",
    "memory": "cpp",
    "istream": "cpp",
    "functional": "cpp",
    "tuple": "cpp",
    "utility": "cpp",
